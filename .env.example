# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=deepseek                # deepseek (default) | nvidia
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-chat         # ghi rõ snapshot khi báo cáo metrics
# NVIDIA_API_KEY=nvapi-your-key-here
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
LLM_TIMEOUT=120                      # v4-pro (reasoning) cần ~900
LLM_RETRIES=3
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2                  # >0 để pass@k/bootstrap có biến thiên (validator A4 vẫn tất định)
# Per-agent caps — KHÔNG fallback về LLM_MAX_TOKENS, phải set tường minh. Default code:
# ARCHI=2048 SECU=512 ENGI=4096 VAL=256 DEPLOY=256 — quá nhỏ cho v4-pro / plan nhiều resource.
LLM_MAX_TOKENS_ARCHI=8192
LLM_MAX_TOKENS_ENGI=8192
LLM_MAX_TOKENS_SECU=6144             # A2 JSON map nhiều resource (label dài) → cần headroom, tránh truncate → mất security
LLM_MAX_TOKENS_VAL=2048
LLM_MAX_TOKENS_DEPLOY=2048

# ── AWS (cần cho terraform plan/apply + Rego semantic eval) ───────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Tooling ───────────────────────────────────────────────────────────────────
TF_PLAN_TIMEOUT=120                  # Terraform plan timeout (giây)
